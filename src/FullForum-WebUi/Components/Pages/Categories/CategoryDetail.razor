@page "/categories/{Id:guid}"
@using FullForum_WebUi.Models.Threads
@using FullForum_WebUi.Services
@using FullForum_WebUi.Services.Exceptions
@using FullForum_WebUi.Services.UI

@using FullForum_WebUi.Models.Category
@inject ApiClient Api
@inject IUiStatus Ui

<PageTitle>Category</PageTitle>

<div class="threads-page">
    <p><a href="/home" style="color:white;text-decoration:none">&lt; Back to Home</a></p>

        <div>
            @if (Ui.Error is not null)
            {
                <div class="alert alert-danger">
                    <strong>@Ui.Error.Title</strong>
                    <div>@Ui.Error.Detail</div>
                </div>
            }
            else if (Ui.IsBusy)
            {
                <div class="card categories-container">
                    <h2>Category</h2>
                    <p style="color:#aaaaaa;">Loading...</p>
                </div>  
            }
            else if (_category is null)
            {
                <div class="card categories-container">
                <h2>Category not found</h2>
                </div>
            }
            else if (_threads is not null)
            {
                <div class="card categories-container">
                    <h2>Category: @_category.CategoryName</h2>
                    <div class="home-thread-meta">
                        @* Show the most recently updated thread date or "-" if no thread exists *@
                        <span class="home-meta-item">Last updated: @(_threads.Items.Any() ? _threads.Items.Max(t => t.UpdatedAt ?? t.CreatedAt).ToString("yyyy-MM-dd HH:mm") : "—")</span>
                        <span class="home-meta-item">@_threads.TotalCount thread@(_threads.TotalCount == 1 ? "" : "s")</span>
                    </div>

                    <div class="card-inner" style="color:white; margin-top:1.5rem">
                        @_category.CategoryDescription
                    </div>

                    <a href="/threads/create" class="btn-submit" style="display:inline-block; text-decoration:none;">
                        Create thread
                    </a>
                </div>

                <div class="card categories-container" style="margin-top: 1.5rem; margin-bottom: 3rem;">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <h2>Threads in this category</h2>
                        <div>
                        <button @onclick="() => ChangePage(_currentPage - 1)" disabled="@(_currentPage == 1)" style="color: white; background: none; box-shadow:none; border:none;">❮</button>
                        <span style="color: white">Page @_currentPage of @_totalPages</span>
                        <button @onclick="() => ChangePage(_currentPage + 1)" disabled="@(_currentPage == _totalPages)" style="color: white; background: none; box-shadow:none; border:none;">❯</button>
                        </div>
                    </div>
                    
                    @* VG: Sorting keys *@
                    <div style="display:flex; gap:0.5rem; margin-bottom:1rem; align-items:center;">
                        <span style="color:white;">Sort by:</span>
                        <button @onclick="() => SetSort(SortKey.Date)" style="color:white; background:none; border:none; box-shadow:none; padding:0.3rem 0.7rem; cursor:pointer; font-size:1rem;">
                            Date @(_currentSortKey == SortKey.Date ? (_descending ? "▼" : "▲") : "")
                        </button>
                        <button @onclick="() => SetSort(SortKey.Comments)" style="color:white; background:none; border:none; box-shadow:none; padding:0.3rem 0.7rem; cursor:pointer; font-size:1rem;">
                            Comments @(_currentSortKey == SortKey.Comments ? (_descending ? "▼" : "▲") : "")
                        </button>
                    </div>
                    
                    @if (_threads.TotalCount == 0)
                    {
                        <p class="home-muted">No threads in this category yet.</p>
                    }
                    else
                    {
                        <div class="home-threads-list">
                            @foreach (var t in _threads.Items)
                            {
                                <a href="@($"/threads/{t.Id}")" class="card-inner home-thread-item">
                                    <h3>@t.ThreadTitle</h3>
                                    @* Shorten long threads to 500 characters *@
                                    <p class="home-thread-desc">@(t.ThreadContent.Length > 550 ? t.ThreadContent.Substring(0, 550) + "..." : t.ThreadContent)</p>
                                    <div class="home-thread-meta">
                                    <span class="home-meta-item"><i class="bi bi-person"></i> @t.DisplayName</span>
                                    @* Fallback to CreatedAt if thread has never been updated *@
                                    <span class="home-meta-item"><i class="bi bi-clock"></i> Last updated: @((t.UpdatedAt ?? t.CreatedAt).ToString("yyyy-MM-dd HH:mm"))</span>
                                    <span class="home-meta-item"><i class="bi bi-chat"></i> @t.CommentCount comment@(t.CommentCount == 1 ? "" : "s")</span>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                </div>
            }
        </div>
</div>

@code {
    [Parameter] public Guid Id { get; set; } // Route parameter from URL
    private CategoryDto? _category; // Category loaded from Api
    private PagedThreadsModel? _threads; // Paged threads for category
    int _currentPage = 1; // Current pagination page
    int _totalPages = 1; // Total n of pages

    private enum SortKey { Date, Comments } // Options for sorting
    private SortKey _currentSortKey = SortKey.Date; // VG: Active sorting key
    private bool _descending = true; // VG: Sort direction (true= descending)

    /// <summary>
    /// Loads category and threads when parameters change
    /// </summary>
    protected override async Task OnParametersSetAsync()
    {
        _category = null;
        _threads = null;
        Ui.SetError(null);
        Ui.Offline(false);
        Ui.Busy(true);

        try
        {
            _category = await Api.GetCategoryAsync(Id);
            _threads = await Api.GetThreadsAsync(
                categoryId: Id,
                page: _currentPage,
                sortBy: _currentSortKey == SortKey.Comments ? "comments" : "date",
                descending: _descending
                );

            _totalPages = (int)Math.Ceiling((double)_threads.TotalCount / 5); // 5 threads per page
        }
        catch (HttpRequestException)
        {
            Ui.Offline(true);
            Ui.SetError(new UiError("Offline", "Cannot reach server."));
        }
        catch (ApiProblemException ex)
        {
            Ui.SetError(new UiError("API Error", ex.Message ?? "Something went wrong."));
        }
        catch (Exception ex)
        {
            Ui.SetError(new UiError("Error", ex.Message));
        }
        finally
        {
            Ui.Busy(false); // Re-enable submit-button
        }
    }

    /// <summary>
    /// Navigates to page and reloads thread list
    /// </summary>
    /// <param name="newPage"></param>
    async Task ChangePage(int newPage)
    {
        _currentPage = newPage;
        await OnParametersSetAsync();
    }

    /// <summary>
    /// Set sort key, changes direction
    /// </summary>
    /// <param name="key"></param>
    async Task SetSort(SortKey key)
    {
        if (_currentSortKey == key)
        {
            _descending = !_descending;
        }
        else
        {
            _currentSortKey = key;
            _descending = true;
            
        }
        _currentPage = 1;
        await OnParametersSetAsync();
    }
}