@page "/"
@page "/login"
@layout Layout.PublicLayout
@using System.ComponentModel.DataAnnotations
@using FullForum_WebUi.Services
@using FullForum_WebUi.Services.Auth
@using FullForum_WebUi.Services.Exceptions
@using FullForum_WebUi.Services.UI
@inject ApiClient Api
@inject ITokenStore Tokens
@inject AuthState Auth
@inject IUiStatus Ui
@inject NavigationManager Nav
@inject IJSRuntime Js

<PageTitle>Login</PageTitle>

<main class="login-page">
    <section class="login-shell">
        <div class="login-brand">
            <h1>FullForum</h1>
            <p>Join discussions, share ideas, and connect with the community.</p>
        </div>

        <div class="login-card">
            <EditForm Model="@model" OnValidSubmit="LoginAsync">
                <DataAnnotationsValidator />

                <h2>Welcome back</h2>
                <p class="login-subtitle">Sign in to continue</p>

                @if (Ui.Error is not null)
                {
                    <div class="alert-error">
                        <strong>@Ui.Error.Title</strong>
                        <div>@Ui.Error.Detail</div>
                    </div>
                }

                <div class="form-group">
                    <label for="email">Email</label>
                    <InputText id="email" @bind-Value="model.Email" class="form-input" />
                    <ValidationMessage For="() => model.Email" />
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <InputText id="password" type="password" @bind-Value="model.Password" class="form-input" />
                    <ValidationMessage For="() => model.Password" />

                    @if (_loginError is not null)
                    {
                        <div class="validation-message">@_loginError</div>
                    }
                </div>

                <button type="submit" class="btn-submit" disabled="@Ui.IsBusy">
                    @(Ui.IsBusy ? "Logging in..." : "Login")
                </button>
            </EditForm>

            <div class="login-register-link">
                <a href="/register">Don’t have an account? Register here</a>
            </div>
        </div>
    </section>
</main>

@code {
    private LoginModel model = new();
    private string? _loginError;

    private class LoginModel
    {
        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Enter a valid email")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters")]
        public string Password { get; set; } = "";
    }

    private async Task LoginAsync()
    {
        Ui.SetError(null);
        Ui.Offline(false);
        _loginError = null;
        Ui.Busy(true);

        try
        {
            var result = await Api.LoginAsync(model.Email, model.Password);
            Tokens.SetToken(result.Token);
            await Js.InvokeVoidAsync("localStorage.setItem", "auth_token", result.Token);

            var role = result.Roles.Contains("Admin") ? "Admin" : "User";
            var name = result.DisplayName ?? result.Email ?? model.Email;

            Auth.SignIn(result.UserId, role, name);
            Nav.NavigateTo("/home");
        }
        catch (ApiProblemException ex) when (ex.Status == 401)
        {
            _loginError = "Invalid email or password.";
        }
        catch (HttpRequestException)
        {
            Ui.Offline(true);
            Ui.SetError(new UiError("Offline", "Cannot reach the server."));
        }
        catch (Exception ex)
        {
            Ui.SetError(new UiError("Error", ex.Message));
        }
        finally
        {
            Ui.Busy(false);
        }
    }
}