@using FullForum_WebUi.Services
@using FullForum_WebUi.Services.Auth
@inject AuthState Auth
@inject ITokenStore Tokens
@inject NavigationManager Nav
@inject IJSRuntime Js
@implements IDisposable

<div class="topnav">
    <div class="topnav-title">
        <h1>FullForum</h1>
    </div>
    <div class="topnav-links">
        @if (Auth.IsAuthenticated)
        {
            <a href="/home">Home</a>
            <a href="/profile">Profile</a>
            <button class="logout-btn" @onclick="Logout">Logout</button>
        }
    </div>
</div>

@code {
    // Subscribe to auth changes
    protected override void OnInitialized()
    {
        Auth.OnChanged += OnAuthChanged;
    }
    // Unsubscribe from auth changes
    public void Dispose()
    {
        Auth.OnChanged -= OnAuthChanged;
    }
    // Refresh component when auth state changes
    private void OnAuthChanged() => InvokeAsync(StateHasChanged);
    // Logout user
    private async Task Logout()
    {
        Tokens.SetToken(null);
        await Js.InvokeVoidAsync("localStorage.removeItem", "auth_token");
        Auth.SignOut();
        Nav.NavigateTo("/login");
    }
}